<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/assets/img/logo/lungs.png" type="image/x-icon" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <link rel="stylesheet" href="/assets/css/stylecustomlogin.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <title>CardioTrack Pro | Secure Login</title>
</head>

<body>
    <div class="login-card">
        <div class="info-panel">
            <div class="brand-section">
                <div class="brand-logo"><i class="fas fa-heartbeat"></i></div>
                <h4 class="m-0 fw-bold">PatientTrack<span style="color:var(--accent-cyan)">PRO</span></h4>
            </div>

            <div>
                <h3 class="fw-bold mb-3">Sistem Pemantauan Pasien</h3>
                <p class="text-white-50">Akses portal terpusat untuk dokter dan tenaga medis rumah sakit</p>
                <ul class="features-list">
                    <li><i class="fas fa-shield-check"></i> <span>Enkripsi data tingkat tinggi sesuai standar protokol
                            kesehatan.</span></li>
                    <li><i class="fas fa-chart-line"></i> <span>Analisis data real-time dengan algoritma deteksi
                            anomali.</span></li>
                    <li><i class="fas fa-user-md"></i> <span>Manajemen riwayat pasien dan integrasi rekam medis
                            elektrik.</span></li>
                </ul>
            </div>

            <div class="badge-secure" style="background: rgba(255,255,255,0.1); color: white;">
                <i class="fas fa-lock"></i> Secured by Encryption
            </div>
        </div>

        <div class="form-panel">

            <div class="form-header">
                <h2>Otentikasi Staf</h2>
                <p>Silakan masuk dengan kredensial medis resmi Anda.</p>
            </div>

            <form action="/auth/login" method="POST">
                <div class="input-wrapper">
                    <label class="form-label">ID Email Medis</label>
                    <i class="fas fa-envelope prefix-icon"></i>
                    <input type="email" name="email" class="form-control" placeholder="staff_name@hospital.id" required>
                </div>

                <div class="input-wrapper">
                    <label class="form-label">Kata Sandi</label>
                    <i class="fas fa-shield-alt prefix-icon"></i>
                    <input type="password" id="password" name="password" class="form-control" placeholder="••••••••"
                        required>
                    <span id="togglePassword">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </span>
                </div>

                <!--            <div class="d-flex justify-content-between align-items-center mb-4">-->
                <!--                <div class="form-check">-->
                <!--                    <input class="form-check-input" type="checkbox" id="remember">-->
                <!--                    <label class="form-check-label small" for="remember">Biarkan saya tetap masuk</label>-->
                <!--                </div>-->
                <!--                <a href="#" class="small text-decoration-none fw-bold" style="color: var(&#45;&#45;medical-blue);">Lupa Akses?</a>-->
                <!--            </div>-->

                <button type="submit" class="btn btn-submit mb-4">
                    <span>Masuk ke Sistem</span>
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div class="text-center mt-auto">
                <p class="text-muted small">Butuh bantuan teknis? <a href="#" class="text-dark fw-bold">Pusat
                        Bantuan</a></p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const passwordInput = document.querySelector('#password');
        const eyeIcon = document.querySelector('#eyeIcon');

        togglePassword.addEventListener('click', function () {
            const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
            passwordInput.setAttribute('type', type);
            eyeIcon.classList.toggle('fa-eye');
            eyeIcon.classList.toggle('fa-eye-slash');
        });

    <% if (typeof alert !== 'undefined') { %>
            Swal.fire({
                icon: '<%= alert.type %>',
                title: '<%= alert.type === "success" ? "Verifikasi Berhasil" : "Gagal Masuk" %>',
                text: '<%= alert.message %>',
                confirmButtonColor: '#2563EB',
                customClass: { popup: 'border-radius-15' }
            });
    <% } %>
    </script>
</body>

</html>