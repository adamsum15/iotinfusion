<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= typeof title !=='undefined' ? title : 'Dashboard Monitoring' %>
  </title>

  <link rel="icon" href="/assets/img/logo/lungs.png" type="image/x-icon" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
    rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/assets/css/kaiadmin.min.css" />
  <link rel="stylesheet" href="/assets/css/stylecustom.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
  <script src="https://cdn.plot.ly/plotly-2.16.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/mqtt@4.3.7/dist/mqtt.min.js"></script>
</head>

<body>
  <div class="wrapper">
    <div class="main-panel" style="width: 100%; float: none;">
      <div class="container-fluid">
        <div class="page-inner">
          <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between pt-4 pb-4">
            <div>
              <h2 class="fw-bold text-dark mb-1">Monitoring</h2>
              <p class="text-muted mb-0">Selamat datang, <strong>
                  <%= user.name %>
                </strong>. Pantau kondisi vital pasien.</p>
            </div>
            <div class="d-flex gap-2 mt-3 mt-md-0">
              <a href="/device1" class="btn btn-secondary d-flex align-items-center gap-2 shadow-sm"
                style="border-radius: 12px; padding: 10px 18px; font-weight: 600;">Device Unit 1
              </a>
              <a href="/device2" class="btn btn-secondary d-flex align-items-center gap-2 shadow-sm"
                style="border-radius: 12px; padding: 10px 18px; font-weight: 600;">Device Unit 2
              </a>
              <button class="btn btn-success d-flex align-items-center gap-2 shadow-sm"
                style="border-radius: 12px; padding: 10px 18px; font-weight: 600;" onclick="validateAndDownload()">
                <span class="material-symbols-outlined" style="font-size: 20px;">download</span>
              </button>
              <a href="/Patient" class="btn btn-dark d-flex align-items-center gap-2 shadow-sm"
                style="border-radius: 12px; padding: 10px 18px; font-weight: 600;"><span
                  class="material-symbols-outlined" style="font-size: 20px;">settings</span>
              </a>
              <div id="current-time"></div>
              <button class="btn btn-primary btn-round px-4 shadow-sm d-flex align-items-center" data-bs-toggle="modal"
                data-bs-target="#modalTambahPasien">
                <span class="material-symbols-rounded me-2">person_add</span> Tambah Pasien
              </button>
              <button id="logoutBtn" class="btn btn-logout btn-round px-3 shadow-sm d-flex align-items-center"
                title="Keluar">
                <span class="material-symbols-rounded">logout</span>
              </button>
            </div>
          </div>

          <div class="row">
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-icon bg-soft-primary text-primary"><span class="material-symbols-rounded">groups</span>
                </div>
                <div><small class="text-muted fw-bold d-block">TOTAL PASIEN</small><span class="h3 fw-bold mb-0">
                    <%= allPatients.length %>
                  </span></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-icon bg-soft-success text-success"><span
                    class="material-symbols-rounded">sensors</span></div>
                <div><small class="text-muted fw-bold d-block">STATUS ALAT</small><span
                    class="h3 fw-bold mb-0">Aktif</span></div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="stat-card">
                <div class="stat-icon bg-soft-warning text-warning"><span
                    class="material-symbols-rounded">health_metrics</span></div>
                <div><small class="text-muted fw-bold d-block">SISTEM</small><span class="h3 fw-bold mb-0">Normal</span>
                </div>
              </div>
            </div>
          </div>

          <div class="card">
            <div
              class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 p-4">
              <h5 class="card-title fw-bold mb-0">Daftar Pasien Monitoring</h5>
              <div class="search-container position-relative">
                <span class="material-symbols-rounded">search</span>
                <input type="text" id="tableSearch" class="form-control input-search"
                  placeholder="Cari nama, ID, atau kamar...">
              </div>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table align-items-center mb-0 border-0">
                  <thead>
                    <tr>
                      <th class="ps-4 border-0">Informasi Pasien</th>
                      <th class="border-0">Lokasi & Status</th>
                      <th class="border-0">Ambang Batas Vital</th>
                      <th class="border-0">Kapasitas Infus</th>
                      <th class="text-end pe-4 border-0">Aksi</th>
                    </tr>
                  </thead>
                  <tbody id="patientTableBody">
                    <% if (allPatients.length> 0) { %>
                      <% allPatients.forEach(p=> { %>
                        <tr class="patient-row">
                          <td class="ps-4">
                            <div class="d-flex align-items-center">
                              <div class="avatar-sm me-3">
                                <div class="avatar-title rounded-circle bg-soft-primary fw-bold"
                                  style="font-size: 1.2rem;">
                                  <%= p.name.charAt(0).toUpperCase() %>
                                </div>
                              </div>
                              <div>
                                <div class="fw-bold text-dark mb-0 patient-name" style="font-size: 1rem;">
                                  <%= p.name %>
                                </div>
                                <div class="d-flex align-items-center">
                                  <span class="badge bg-light text-muted border-0 p-0 me-2 patient-id"
                                    style="font-size: 0.75rem;">PX-<%= p.id %>
                                  </span>
                                  <span class="badge bg-soft-success text-success px-2 py-0"
                                    style="font-size: 10px;">AKTIF</span>
                                </div>
                              </div>
                            </div>
                          </td>

                          <td>
                            <div class="d-flex align-items-center mb-1">
                              <span class="status-pulse"></span>
                              <span class="fw-bold text-dark">Kamar <%= p.no_room %>
                              </span>
                            </div>
                            <div class="small text-muted">
                              <span class="material-symbols-rounded align-middle" style="font-size: 14px;">router</span>
                              Unit 0<%= p.device_id %> • Bed <%= p.no_bed %>
                            </div>
                          </td>

                          <td>
                            <div class="indicator-group">
                              <div class="indicator-item">
                                <span class="indicator-label">HR Max</span>
                                <span class="indicator-value text-danger">
                                  <i class="material-symbols-rounded align-middle" style="font-size: 14px;">favorite</i>
                                  <%= p.threshold_hr %>
                                </span>
                              </div>
                              <div class="indicator-item">
                                <span class="indicator-label">SpO2 Min</span>
                                <span class="indicator-value text-primary">
                                  <i class="material-symbols-rounded align-middle" style="font-size: 14px;">air</i>
                                  <%= p.threshold_spo || '95' %>%
                                </span>
                              </div>
                            </div>
                          </td>

                          <td>
                            <div class="infus-container">
                              <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="fw-bold text-dark" style="font-size: 13px;">
                                  <%= p.threshold_infus || '20' %>%
                                </span>
                                <span class="material-symbols-rounded text-warning"
                                  style="font-size: 16px;">water_drop</span>
                              </div>
                              <div class="progress progress-thin">
                                <div class="progress-bar bg-warning" role="progressbar"
                                  style="width: <%= p.threshold_infus || '20' %>%">
                                </div>
                              </div>
                            </div>
                          </td>

                          <td class="text-end pe-4">
                            <div class="d-flex justify-content-end align-items-center gap-2">
                              <button onclick="confirmDeletePatient('<%= p.id %>', '<%= p.name %>')"
                                class="btn btn-delete-soft d-flex align-items-center justify-content-center"
                                title="Hapus Pasien">
                                <span class="material-symbols-rounded" style="font-size: 20px;">delete</span>
                              </button>

                              <a href="/device<%= p.id %>"
                                class="btn btn-action d-inline-flex align-items-center shadow-sm">
                                <span>Detail</span>
                                <span class="material-symbols-rounded ms-2"
                                  style="font-size: 18px;">arrow_forward</span>
                              </a>
                            </div>
                          </td>
                        </tr>
                        <% }) %>
                          <% } else { %>
                            <tr>
                              <td colspan="5" class="text-center p-5 text-muted">Tidak ada
                                data pasien ditemukan.</td>
                            </tr>
                            <% } %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="modal fade" id="modalTambahPasien" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
        <div class="modal-header p-4 border-0" style="background: var(--primary-gradient);">
          <div class="d-flex align-items-center">
            <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
              <span class="material-symbols-rounded text-white">person_add</span>
            </div>
            <h5 class="modal-title fw-bold text-white">Registrasi Pasien Baru</h5>
          </div>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <form action="/patients/add" method="POST">
          <div class="modal-body p-4">
            <input type="hidden" name="device_id" value="<%= activePage === 'device1' ? '1' : '2' %>">
            <div class="row g-3">
              <div class="col-12">
                <label class="form-label fw-bold small text-muted">NAMA LENGKAP PASIEN</label>
                <input type="text" name="name" class="form-control input-custom shadow-none"
                  placeholder="Masukkan nama..." required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold small text-muted">USIA</label>
                <input type="number" name="age" class="form-control input-custom shadow-none" required>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold small text-muted">JENIS KELAMIN</label>
                <select name="gender" class="form-select input-custom shadow-none">
                  <option value="Male">Laki-laki</option>
                  <option value="Female">Perempuan</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold small text-muted">Nama KAMAR</label>
                <input type="text" name="no_room" class="form-control input-custom shadow-none"
                  placeholder="Contoh: Jasmine">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold small text-muted">NO. BED</label>
                <input type="text" name="no_bed" class="form-control input-custom shadow-none" placeholder="Contoh: 1">
              </div>
              <div class="col-12 mt-4">
                <div class="p-3 bg-light rounded-4 border border-dashed">
                  <h6 class="fw-bold text-primary mb-3 d-flex align-items-center">
                    <span class="material-symbols-rounded me-2" style="font-size: 18px;">settings_heart</span>
                    Parameter Ambang Batas
                  </h6>
                  <div class="row g-3">
                    <div class="col-12">
                      <label class="small text-muted fw-600">Max Heart Rate (BPM)</label>
                      <input type="number" name="threshold_hr" class="form-control input-custom bg-white" value="100">
                    </div>
                    <div class="col-6">
                      <label class="small text-muted fw-600">Min SpO2 (%)</label>
                      <input type="number" name="threshold_spo" class="form-control input-custom bg-white" value="95">
                    </div>
                    <div class="col-6">
                      <label class="small text-muted fw-600">Min Infus (%)</label>
                      <input type="number" name="threshold_infus" class="form-control input-custom bg-white" value="15">
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="modal-footer border-0 p-4 pt-0">
            <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold"
              data-bs-dismiss="modal">Batal</button>
            <button type="submit" class="btn btn-primary px-5 btn-round shadow">Simpan Data</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="/assets/js/core/jquery-3.7.1.min.js"></script>
  <script src="/assets/js/core/bootstrap.min.js"></script>
  <script src="/assets/js/kaiadmin.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    function validateAndDownload() {
      window.location.href = '/export/patient';
    };

    // Konfirmasi Logout
    document.getElementById('logoutBtn').addEventListener('click', function (e) {
      e.preventDefault();
      Swal.fire({
        title: 'Yakin ingin keluar?',
        text: "Sesi monitoring Anda akan berakhir.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#4361ee',
        cancelButtonColor: '#f43f5e',
        confirmButtonText: 'Ya, Keluar',
        cancelButtonText: 'Batal'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = "/auth/logout";
        }
      });
    });

    function updateClock() {
      const now = new Date();
      const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
      document.getElementById('current-time').innerText = now.toLocaleString('id-ID', options);
    }
    setInterval(updateClock, 1000);
    updateClock();
  </script>

  <script>
    // Fungsi Konfirmasi Hapus Pasien (Soft Delete)
    function confirmDeletePatient(id, name) {
      Swal.fire({
        title: 'Hapus Pasien?',
        text: `Apakah Anda yakin ingin menghapus data pasien ${name}? Data akan dipindahkan ke arsip.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#ef4444',
        cancelButtonColor: '#94a3b8',
        confirmButtonText: 'Ya, Hapus!',
        cancelButtonText: 'Batal',
        reverseButtons: true
      }).then((result) => {
        if (result.isConfirmed) {
          // Mengarahkan ke route delete yang sudah dibuat di backend
          window.location.href = `/patients/delete/${id}`;
        }
      });
    }

    // Pencarian Real-time
    document.getElementById('tableSearch').addEventListener('keyup', function () {
      const value = this.value.toLowerCase();
      const rows = document.querySelectorAll('#patientTableBody .patient-row');
      rows.forEach(row => {
        const rowText = row.innerText.toLowerCase();
        row.style.display = rowText.includes(value) ? "" : "none";
      });
    });

    // Konfirmasi Logout
    document.getElementById('logoutBtn').addEventListener('click', function (e) {
      e.preventDefault();
      Swal.fire({
        title: 'Yakin ingin keluar?',
        text: "Sesi monitoring Anda akan berakhir.",
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#4361ee',
        cancelButtonColor: '#f43f5e',
        confirmButtonText: 'Ya, Keluar',
        cancelButtonText: 'Batal'
      }).then((result) => {
        if (result.isConfirmed) {
          window.location.href = "/auth/logout";
        }
      });
    });

    // Alert sukses flash message
    <% if (typeof message !== 'undefined') { %>
      Swal.fire({
        icon: 'success',
        title: 'Berhasil',
        text: '<%= message %>',
        timer: 3000,
        showConfirmButton: false
      });
    <% } %>
  </script>
</body>

</html>