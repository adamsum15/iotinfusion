<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= typeof title !=='undefined' ? title : 'Dashboard Monitoring' %>
    </title>

    <link rel="icon" href="/assets/img/logo/lungs.png" type="image/x-icon" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
        rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/kaiadmin.min.css" />
    <link rel="stylesheet" href="/assets/css/stylecustom.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.plot.ly/plotly-2.16.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mqtt@4.3.7/dist/mqtt.min.js"></script>
</head>

<body>
    <div class="wrapper">
        <div class="main-panel" style="width: 100%; float: none;">
            <div class="container-fluid">
                <div class="page-inner">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between pt-4 pb-4">
                        <div>
                            <h2 class="fw-bold text-dark mb-1">Monitoring Device <%= patient.device_id %>
                            </h2>
                            <p class="text-muted mb-0">Selamat datang,<strong>
                                    <% if (user) { %>
                                        <%= user.name %>
                                            <% } %>
                                </strong>. Pantau kondisi vital pasien.</p>
                        </div>
                        <div class="d-flex gap-2 mt-3 mt-md-0">
                            <div class="d-flex align-items-center gap-2">
                                <a href="/device1" class="btn btn-secondary d-flex align-items-center gap-2 shadow-sm"
                                    style="border-radius: 12px; padding: 10px 18px; font-weight: 600;">Device
                                    Unit 1
                                </a>
                                <a href="/device2" class="btn btn-secondary d-flex align-items-center gap-2 shadow-sm"
                                    style="border-radius: 12px; padding: 10px 18px; font-weight: 600;">Device
                                    Unit 2
                                </a>
                                <button class="btn btn-success d-flex align-items-center gap-2 shadow-sm"
                                    style="border-radius: 12px; padding: 10px 18px; font-weight: 600;"
                                    onclick="validateAndDownload()">
                                    <span class="material-symbols-outlined" style="font-size: 20px;">download</span>
                                </button>
                                <div id="current-time"></div>
                            </div>
                            <button class="btn btn-primary btn-round px-4 shadow-sm d-flex align-items-center"
                                data-bs-toggle="modal" data-bs-target="#modalAddPasien">
                                <span class="material-symbols-rounded me-2">person_add</span> Tambah Pasien
                            </button>
                            <button id="logoutBtn"
                                class="btn btn-logout btn-round px-3 shadow-sm d-flex align-items-center"
                                title="Keluar">
                                <span class="material-symbols-rounded">logout</span>
                            </button>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card card-round card-profile">
                                <div
                                    class="card-header profile-header-gradient d-flex justify-content-between align-items-center px-3 py-3">
                                    <div class="d-flex gap-2 p-3">
                                        <button
                                            class="btn btn-warning btn-sm btn-round px-4 shadow-sm d-flex align-items-center"
                                            data-bs-toggle="modal" data-bs-target="#modalPilihPasien">
                                            <span class="material-symbols-rounded me-2">person</span>
                                        </button>
                                        <button
                                            class="btn btn-danger btn-sm btn-round px-4 shadow-sm d-flex align-items-center"
                                            data-bs-toggle="modal" data-bs-target="#modalSync">
                                            <span class="material-symbols-rounded me-2">autorenew</span>
                                        </button>
                                    </div>
                                    <% if (patient) { %>
                                        <button
                                            class="btn btn-white btn-sm shadow-sm d-flex align-items-center justify-content-center"
                                            style="width: 48px; height: 48px; border-radius: 12px;"
                                            data-bs-toggle="modal" data-bs-target="#modalEditPasien">
                                            <span class="material-symbols-outlined" style="font-size:18px;">edit</span>
                                        </button>
                                        <% } %>
                                </div>
                                <br>
                                <div class="card-body text-center">
                                    <div class="avatar-container" style="margin-top: -65px; margin-bottom: 15px;">
                                        <div class="avatar-wrapper">
                                            <div class="d-flex align-items-center justify-content-center bg-light rounded-circle"
                                                style="width: 90px; height: 90px;">
                                                <span class="material-symbols-outlined"
                                                    style="font-size: 55px; color: #cbd5e0;">person</span>
                                            </div>
                                        </div>
                                    </div>

                                    <h3 class="fw-bold mb-1 text-dark">
                                        <%= (patient && patient.name) ? patient.name : 'Pasien Tidak Ditemukan' %>
                                    </h3>
                                    <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm"
                                        style="font-size: 0.75rem; letter-spacing: 1px;"> RM
                                        <%= (patient && patient.id) ? patient.no_rm : '000' %>
                                    </span>

                                    <div class="mt-4 text-start">
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">calendar_month</span> Umur</span>
                                            <span class="fw-bold text-dark">
                                                <%= patient ? patient.age : '-' %> Thn
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">wc</span> Gender</span>
                                            <span class="fw-bold text-dark">
                                                <%= patient && patient.gender==='Laki-Laki' ? 'Laki-Laki' : 'Perempuan'
                                                    %>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">meeting_room</span> Lokasi</span>
                                            <span class="fw-bold text-primary text-end">Ruang <%= patient ?
                                                    patient.name_room : '-' %> <br> Room <%= patient ? patient.no_room
                                                        : '-' %> <br> Bed <%= patient ? patient.no_bed : '-' %></span>
                                        </div>
                                        <div class="mt-4 p-3 rounded-4"
                                            style="background-color: #f8fafc; border: 1px solid #edf2f7;">
                                            <p class="small fw-bold text-muted mb-3 text-uppercase"
                                                style="font-size: 0.65rem; letter-spacing: 1px;">Threshold Alarm</p>
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="d-flex align-items-center gap-2 text-danger">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">favorite</span>
                                                    <span class="small fw-semibold">Heart Rate</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_hr%> BPM
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="d-flex align-items-center gap-2 text-primary">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">blood_pressure</span>
                                                    <span class="small fw-semibold">SpO2 Min</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_spo%> %
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center gap-2 text-warning">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">opacity</span>
                                                    <span class="small fw-semibold">Infus Warning</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_infus_warning%> mL
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center gap-2 text-dark">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">opacity</span>
                                                    <span class="small fw-semibold">Infus Danger</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_infus_danger%> mL
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3">
                                <!-- CARD STATUS KONEKSI -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm border-0">
                                        <div class="card-body p-3 text-center connection-status">
                                            <span class="status-dot"></span>
                                            <span class="fw-bold text-success status"
                                                style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                                DISCONNECTED
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- CARD BATTERY -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm border-0">
                                        <div class="card-body p-3 text-center">
                                            <span class="fw-bold text-black"
                                                style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                                BATTERY : <span id="batt"></span>%
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-danger"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">favorite</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Heart Rate</p>
                                                        <h3 id="heart">BPM</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-primary"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">blood_pressure</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">SpO2</p>
                                                        <h3 id="spo">%</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-warning"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">opacity</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Infusion</p>
                                                        <h3 id="infus">mL</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-info"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">device_thermostat</span>
                                                    </div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Chip Temp</p>
                                                        <h3 id="temp">°C</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="page-inner">
                                <div class="row">
                                    <div class="col-sm-12 col-md-6">
                                        <div id="heart-history"></div>
                                    </div>
                                    <div class="col-sm-12 col-md-6">
                                        <div id="spo-history"></div>
                                    </div>
                                </div>
                                <br>
                                <div class="row">
                                    <div class="col-sm-12 col-md-6">
                                        <div id="temp-history"></div>
                                    </div>
                                    <div class="col-sm-12 col-md-6">
                                        <div id="infus-history"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalEditPasien" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
                <div class="modal-header p-4 border-0" style="background: var(--primary-gradient);">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                            <span class="material-symbols-rounded text-white">person</span>
                        </div>
                        <h5 class="modal-title fw-bold text-white">Edit Data Pasien</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/patients/edit" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="patient_id" value="<%= patient.id %>">
                        <input type="hidden" name="device_id" value="<%= patient.device_id %>">
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted">NAMA LENGKAP PASIEN</label>
                                <input type="text" name="name" class="form-control input-custom shadow-none"
                                    value="<%=patient.name%>" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted">No. RM</label>
                                <input type="number" name="no_rm" class="form-control input-custom shadow-none"
                                    value="<%=patient.no_rm%>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">USIA</label>
                                <input type="number" name="age" class="form-control input-custom shadow-none"
                                    value="<%=patient.age%>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">JENIS KELAMIN</label>
                                <select name="gender" class="form-select input-custom shadow-none">
                                    <option value="Laki-Laki" <%=patient.gender==='Laki-Laki' ? 'selected' : '' %>>
                                        Laki-Laki
                                    </option>
                                    <option value="Perempuan" <%=patient.gender==='Perempuan' ? 'selected' : '' %>>
                                        Perempuan
                                    </option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">Nama Ruang</label>
                                <input type="text" name="name_room" class="form-control input-custom shadow-none"
                                    value="<%=patient.name_room%>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">No. Room</label>
                                <input type="number" name="no_room" class="form-control input-custom shadow-none"
                                    value="<%=patient.no_room%>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">No. Bed</label>
                                <input type="number" name="no_bed" class="form-control input-custom shadow-none"
                                    value="<%=patient.no_bed%>" required>
                            </div>
                            <div class="col-12 mt-4">
                                <div class="p-3 bg-light rounded-4 border border-dashed">
                                    <h6 class="fw-bold text-primary mb-3 d-flex align-items-center">
                                        <span class="material-symbols-rounded me-2"
                                            style="font-size: 18px;">settings_heart</span>
                                        Parameter Ambang Batas
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Max Heart Rate (BPM)</label>
                                            <input type="number" name="threshold_hr"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_hr%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Min SpO2 (%)</label>
                                            <input type="number" name="threshold_spo"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_spo%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Warning Infus (mL)</label>
                                            <input type="number" name="threshold_infus_warning"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_infus_warning%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Danger Infus (mL)</label>
                                            <input type="number" name="threshold_infus_danger"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_infus_danger%>" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold"
                            data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary px-5 btn-round shadow">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalPilihPasien" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
                <div class="modal-header p-4 border-0" style="background: var(--primary-gradient);">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                            <span class="material-symbols-rounded text-white">person</span>
                        </div>
                        <h5 class="modal-title fw-bold text-white">Pilih Pasien</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/patients/change" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="last_patient_id" value="<%= patient.id %>">
                        <input type="hidden" name="device_id" value="<%= patient.device_id %>">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold small text-muted">PILIH PASIEN</label>
                                <select name="new_patient_id" class="form-select input-custom shadow-none" required>
                                    <% patients.forEach(p=> { %>
                                        <option value="<%= p.id %>" <%=patient && patient.id===p.id ? 'selected' : '' %>
                                            >
                                            <%= p.name %> — Ruang <%= p.name_room %> — Room <%= p.no_room %> — Bed <%=
                                                            p.no_bed %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold"
                            data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary px-5 btn-round shadow">Lanjutkan</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalSync" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
                <div class="modal-header p-4 border-0" style="background: var(--primary-gradient);">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                            <span class="material-symbols-rounded text-white">autorenew</span>
                        </div>
                        <h5 class="modal-title fw-bold text-white">Sync Threshold Pasien</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/patients/sync" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="last_patient_id" value="<%= patient.id %>">
                        <input type="hidden" name="device_id" value="<%= patient.device_id %>">
                        <p>Synchronization data Threshold Pasien?.</p>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold"
                            data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary px-5 btn-round shadow">Sync</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalAddPasien" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 24px; overflow: hidden;">
                <div class="modal-header p-4 border-0" style="background: var(--primary-gradient);">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-25 p-2 rounded-3 me-3">
                            <span class="material-symbols-rounded text-white">person_add</span>
                        </div>
                        <h5 class="modal-title fw-bold text-white">Registrasi Pasien Baru</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/patients/add" method="POST">
                    <div class="modal-body p-4">
                        <input type="hidden" name="device_id" value="0">
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted">NAMA LENGKAP PASIEN</label>
                                <input type="text" name="name" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: Josh" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold small text-muted">No. RM</label>
                                <input type="number" name="no_rm" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: 12345" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">USIA</label>
                                <input type="number" name="age" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: 25" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted">JENIS KELAMIN</label>
                                <select name="gender" class="form-select input-custom shadow-none">
                                    <option value="Laki-Laki" <%=patient.gender==='Laki-Laki' ? 'selected' : '' %>>
                                        Laki-Laki
                                    </option>
                                    <option value="Perempuan" <%=patient.gender==='Perempuan' ? 'selected' : '' %>>
                                        Perempuan
                                    </option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">Nama Ruang</label>
                                <input type="text" name="name_room" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: Mawar" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">No. Room</label>
                                <input type="number" name="no_room" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: 1" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted">No. Bed</label>
                                <input type="number" name="no_bed" class="form-control input-custom shadow-none"
                                    placeholder="Contoh: 1" required>
                            </div>
                            <div class="col-12 mt-4">
                                <div class="p-3 bg-light rounded-4 border border-dashed">
                                    <h6 class="fw-bold text-primary mb-3 d-flex align-items-center">
                                        <span class="material-symbols-rounded me-2"
                                            style="font-size: 18px;">settings_heart</span>
                                        Parameter Ambang Batas
                                    </h6>
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Max Heart Rate (BPM)</label>
                                            <input type="number" name="threshold_hr"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_hr%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Min SpO2 (%)</label>
                                            <input type="number" name="threshold_spo"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_spo%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Warning Infus (mL)</label>
                                            <input type="number" name="threshold_infus_warning"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_infus_warning%>" required>
                                        </div>
                                        <div class="col-6">
                                            <label class="small text-muted fw-600">Danger Infus (mL)</label>
                                            <input type="number" name="threshold_infus_danger"
                                                class="form-control input-custom bg-white"
                                                value="<%=patient.threshold_infus_danger%>" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold"
                            data-bs-dismiss="modal">Batal</button>
                        <button type="submit" class="btn btn-primary px-5 btn-round shadow">Simpan Data</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/assets/js/core/jquery-3.7.1.min.js"></script>
    <script src="/assets/js/core/bootstrap.min.js"></script>
    <script src="/assets/js/kaiadmin.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="/device1.js"></script>
    <script type="module" src="/mqttService.js"></script>

    <script>
        function validateAndDownload() {
            window.location.href = "export/<%= activePage %>";
        };

        // Konfirmasi Logout
        document.getElementById('logoutBtn').addEventListener('click', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Yakin ingin keluar?',
                text: "Sesi monitoring Anda akan berakhir.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#4361ee',
                cancelButtonColor: '#f43f5e',
                confirmButtonText: 'Ya, Keluar',
                cancelButtonText: 'Batal'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = "/auth/logout";
                }
            });
        });

        function updateClock() {
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
            document.getElementById('current-time').innerText = now.toLocaleString('id-ID', options);
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
    <script>
    <% if (typeof alert !== 'undefined') { %>
            Swal.fire({
                icon: '<%= alert.type %>',
                title: '<%= alert.type === "success" ? "Berhasil!" : "Gagal!" %>',
                text: '<%= alert.message %>',
            });
    <% } %>
    </script>
</body>

</html>