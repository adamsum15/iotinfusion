<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
        <%= typeof title !=='undefined' ? title : 'Dashboard Monitoring' %>
    </title>

    <link rel="icon" href="/assets/img/logo/lungs.png" type="image/x-icon" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
        rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/kaiadmin.min.css" />
    <link rel="stylesheet" href="/assets/css/stylecustom.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.plot.ly/plotly-2.16.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/mqtt@4.3.7/dist/mqtt.min.js"></script>
</head>

<body>
    <div class="wrapper">
        <div class="main-panel" style="width: 100%; float: none;">
            <div class="container-fluid">
                <div class="page-inner">
                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between pt-4 pb-4">
                        <div>
                            <h2 class="fw-bold text-dark mb-1">Public Monitoring Device</h2>
                        </div>
                        <div class="d-flex gap-2 mt-3 mt-md-0">
                            <div class="d-flex align-items-center gap-2">
                                <div id="current-time"></div>
                            </div>
                            <a href="/" class="btn btn-login btn-round px-3 shadow-sm d-flex align-items-center"
                                title="Login">
                                <span class="material-symbols-rounded">login</span>
                            </a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-3">
                            <div class="card card-round card-profile">
                                <div
                                    class="card-header profile-header-gradient d-flex justify-content-between align-items-center px-3 py-3">
                                </div>
                                <br>
                                <div class="card-body text-center">
                                    <div class="avatar-container" style="margin-top: -65px; margin-bottom: 15px;">
                                        <div class="avatar-wrapper">
                                            <div class="d-flex align-items-center justify-content-center bg-light rounded-circle"
                                                style="width: 90px; height: 90px;">
                                                <span class="material-symbols-outlined"
                                                    style="font-size: 55px; color: #cbd5e0;">person</span>
                                            </div>
                                        </div>
                                    </div>

                                    <h3 class="fw-bold mb-1 text-dark">
                                        <%= (patient && patient.name) ? patient.name : 'Pasien Tidak Ditemukan' %>
                                    </h3>
                                    <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm"
                                        style="font-size: 0.75rem; letter-spacing: 1px;"> RM
                                    </span>

                                    <div class="mt-4 text-start">
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">calendar_month</span> Umur</span>
                                            <span class="fw-bold text-dark">
                                                <%= patient ? patient.age : '-' %> Thn
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">wc</span> Gender</span>
                                            <span class="fw-bold text-dark">
                                                <%= patient && patient.gender==='Laki-Laki' ? 'Laki-Laki' : 'Perempuan'
                                                    %>
                                            </span>
                                        </div>
                                        <div class="d-flex justify-content-between info-row">
                                            <span class="text-muted info-label d-flex align-items-center"><span
                                                    class="material-symbols-outlined me-2"
                                                    style="font-size: 18px;">meeting_room</span> Lokasi</span>
                                            <span class="fw-bold text-primary text-end">Ruang <%= patient ?
                                                    patient.name_room : '-' %> <br> Room <%= patient ? patient.no_room
                                                        : '-' %> <br> Bed <%= patient ? patient.no_bed : '-' %></span>
                                        </div>
                                        <div class="mt-4 p-3 rounded-4"
                                            style="background-color: #f8fafc; border: 1px solid #edf2f7;">
                                            <p class="small fw-bold text-muted mb-3 text-uppercase"
                                                style="font-size: 0.65rem; letter-spacing: 1px;">Threshold Alarm</p>
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="d-flex align-items-center gap-2 text-danger">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">favorite</span>
                                                    <span class="small fw-semibold">Heart Rate</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_hr%> BPM
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between mb-2">
                                                <div class="d-flex align-items-center gap-2 text-primary">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">blood_pressure</span>
                                                    <span class="small fw-semibold">SpO2 Min</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_spo%> %
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center gap-2 text-warning">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">opacity</span>
                                                    <span class="small fw-semibold">Infus Warning</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_infus_warning%> mL
                                                </span>
                                            </div>
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="d-flex align-items-center gap-2 text-dark">
                                                    <span class="material-symbols-outlined"
                                                        style="font-size: 18px;">opacity</span>
                                                    <span class="small fw-semibold">Infus Danger</span>
                                                </div>
                                                <span class="small fw-bold text-dark">
                                                    <%=patient.threshold_infus_danger%> mL
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3">
                                <!-- CARD STATUS KONEKSI -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm border-0">
                                        <div class="card-body p-3 text-center connection-status">
                                            <span class="status-dot"></span>
                                            <span class="fw-bold text-success status"
                                                style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                                DISCONNECTED
                                            </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- CARD BATTERY -->
                                <div class="col-md-6">
                                    <div class="card shadow-sm border-0">
                                        <div class="card-body p-3 text-center">
                                            <span class="fw-bold text-black"
                                                style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px;">
                                                BATTERY : <span id="batt"></span>%
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-9">
                            <div class="row">
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-danger"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">favorite</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Heart Rate</p>
                                                        <h3 id="heart">BPM</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-primary"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">blood_pressure</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">SpO2</p>
                                                        <h3 id="spo">%</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-info"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">device_thermostat</span>
                                                    </div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Temp</p>
                                                        <h3 id="temp">°C</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-6 col-md-3">
                                    <div class="card card-stats">
                                        <div class="card-body">
                                            <div class="row align-items-center">
                                                <div class="col-icon">
                                                    <div class="icon-big text-center icon-warning"><span
                                                            class="material-symbols-outlined"
                                                            style="font-size: 28px;">opacity</span></div>
                                                </div>
                                                <div class="col col-stats ms-3">
                                                    <div class="numbers">
                                                        <p class="card-category">Infusion</p>
                                                        <h3 id="infus">%</h3>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="page-inner">
                                <div class="row">
                                    <div class="col-sm-12 col-md-6">
                                        <div id="heart-history"></div>
                                    </div>
                                    <div class="col-sm-12 col-md-6">
                                        <div id="spo-history"></div>
                                    </div>
                                </div>
                                <br>
                                <div class="row">
                                    <div class="col-sm-12 col-md-6">
                                        <div id="temp-history"></div>
                                    </div>
                                    <div class="col-sm-12 col-md-6">
                                        <div id="infus-history"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/assets/js/core/jquery-3.7.1.min.js"></script>
    <script src="/assets/js/core/bootstrap.min.js"></script>
    <script src="/assets/js/kaiadmin.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script type="module" src="/device1.js"></script>
    <script type="module" src="/mqttService.js"></script>

    <script>
        function updateClock() {
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' };
            document.getElementById('current-time').innerText = now.toLocaleString('id-ID', options);
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
</body>

</html>